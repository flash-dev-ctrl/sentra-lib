{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Process",
    "description": "运行中的智能体进程结构，适用于常见桌面和服务器操作系统。",
    "type": "object",
    "required": [
        "pid",
        "command"
    ],
    "additionalProperties": true,
    "properties": {
        "user": {
            "type": [
                "string",
                "null"
            ],
            "description": "运行该进程的操作系统用户。"
        },
        "pid": {
            "type": "integer",
            "description": "进程标识。",
            "minimum": 1
        },
        "start": {
            "type": [
                "string",
                "null"
            ],
            "description": "进程启动时间，格式依赖操作系统。"
        },
        "command": {
            "type": "string",
            "description": "包含参数的完整命令行。"
        },
        "cpu": {
            "type": [
                "number",
                "null"
            ],
            "description": "处理器使用率百分比，允许为空。"
        },
        "mem": {
            "type": [
                "number",
                "null"
            ],
            "description": "内存使用率百分比，允许为空。"
        }
    }
}
