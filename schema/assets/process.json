{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Process",
    "description": "运行中的智能体进程资产结构。",
    "type": "object",
    "required": [
        "pid",
        "name",
        "cmdline",
        "startedAt",
        "runTimeSeconds"
    ],
    "additionalProperties": true,
    "properties": {
        "pid": {
            "type": "integer",
            "description": "进程标识。",
            "minimum": 0
        },
        "name": {
            "type": "string",
            "description": "进程可执行名称。"
        },
        "cmdline": {
            "type": "array",
            "description": "进程命令行参数列表。",
            "items": {
                "type": "string"
            }
        },
        "startedAt": {
            "type": "integer",
            "description": "进程启动时间，Unix 秒级时间戳。",
            "minimum": 0
        },
        "runTimeSeconds": {
            "type": "integer",
            "description": "进程已运行时长，单位为秒。",
            "minimum": 0
        },
        "path": {
            "type": [
                "string",
                "null"
            ],
            "description": "进程可执行文件路径，允许为空。"
        },
        "env": {
            "type": "object",
            "description": "进程环境变量映射，敏感值应已脱敏。",
            "additionalProperties": {
                "type": "string"
            }
        }
    }
}
