{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Provider",
    "description": "模型供应商资产结构。",
    "type": "object",
    "required": [
        "name",
        "enabled"
    ],
    "additionalProperties": true,
    "properties": {
        "name": {
            "type": "string",
            "description": "模型供应商名称。"
        },
        "providerType": {
            "type": "string",
            "description": "供应商采集类型，用于区分模型网关与登录账号。",
            "enum": [
                "gateway",
                "codex_account",
                "claude_account"
            ],
            "default": "gateway"
        },
        "baseUrl": {
            "type": [
                "string",
                "null"
            ],
            "description": "模型服务基础地址，允许为空。"
        },
        "apiKey": {
            "type": [
                "string",
                "null"
            ],
            "description": "模型服务访问密钥，允许为空。"
        },
        "enabled": {
            "type": "boolean",
            "description": "模型供应商是否启用。"
        },
        "models": {
            "type": "array",
            "description": "模型列表。",
            "items": {
                "$ref": "#/definitions/ProviderModel"
            }
        },
        "protocol": {
            "type": [
                "string",
                "null"
            ],
            "description": "模型请求协议，允许为空。",
            "enum": [
                "responses",
                "chat_completions",
                "anthropic_messages",
                null
            ]
        },
        "routeStatus": {
            "type": "string",
            "description": "Endpoint 路由判定：厂商验证直连、未验证、疑似中转、Provider/Endpoint 冲突、自定义、歧义或未知。",
            "enum": [
                "official",
                "unverified",
                "relay_candidate",
                "provider_mismatch",
                "custom",
                "ambiguous",
                "unknown"
            ],
            "default": "unknown"
        },
        "routeReason": {
            "type": [
                "string",
                "null"
            ],
            "description": "非官方或无法确认路由时的判定原因。"
        },
        "endpointTrust": {
            "type": [
                "string",
                "null"
            ],
            "description": "已观测 Endpoint 的来源信任等级；未配置 URL 时为空。",
            "enum": [
                "vendor_verified",
                "models_dev",
                "unverified",
                null
            ]
        },
        "account": {
            "description": "账号型 provider 的登录账号元数据，不包含 token 原文。",
            "anyOf": [
                {
                    "$ref": "#/definitions/ProviderAccount"
                },
                {
                    "type": "null"
                }
            ]
        }
    },
    "definitions": {
        "ProviderAccount": {
            "type": "object",
            "description": "Codex/Claude Code 登录账号元数据。",
            "additionalProperties": true,
            "properties": {
                "accountId": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "账号标识。"
                },
                "email": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "账号邮箱。"
                },
                "displayName": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "账号显示名称。"
                },
                "authMode": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "认证模式。"
                },
                "source": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "账号信息来源。"
                },
                "organizationId": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "组织标识。"
                },
                "organizationName": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "组织名称。"
                },
                "organizationRole": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "账号在组织中的角色。"
                },
                "organizationType": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "组织类型。"
                },
                "billingType": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "账单或订阅类型。"
                },
                "plan": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "套餐或计划。"
                },
                "hasExtraUsageEnabled": {
                    "type": [
                        "boolean",
                        "null"
                    ],
                    "description": "是否启用额外用量。"
                },
                "accountCreatedAt": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "账号创建时间。"
                },
                "subscriptionCreatedAt": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "订阅创建时间。"
                },
                "trialEndsAt": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "试用结束时间。"
                },
                "lastRefresh": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "本地凭据最后刷新时间。"
                },
                "profileFetchedAt": {
                    "type": [
                        "number",
                        "string",
                        "null"
                    ],
                    "description": "账号资料获取时间。"
                },
                "expiresAt": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "凭据或 token 到期时间。"
                },
                "hasIdToken": {
                    "type": [
                        "boolean",
                        "null"
                    ],
                    "description": "是否存在 ID token。"
                },
                "hasAccessToken": {
                    "type": [
                        "boolean",
                        "null"
                    ],
                    "description": "是否存在 access token。"
                },
                "hasRefreshToken": {
                    "type": [
                        "boolean",
                        "null"
                    ],
                    "description": "是否存在 refresh token。"
                },
                "metadata": {
                    "type": "object",
                    "description": "provider 专属扩展元数据。",
                    "additionalProperties": true
                }
            }
        },
        "ProviderModel": {
            "type": "object",
            "description": "模型供应商中的单个模型配置。",
            "required": [
                "id",
                "enabled"
            ],
            "additionalProperties": true,
            "properties": {
                "id": {
                    "type": "string",
                    "description": "模型标识。"
                },
                "name": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "模型显示名称，允许为空。"
                },
                "enabled": {
                    "type": "boolean",
                    "description": "模型是否启用。"
                }
            }
        }
    }
}
